# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# RevenueCat public SDK keys (not secret — from RevenueCat dashboard > Project settings > API keys)
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=

# Sentry crash/error reporting. DSN is not secret (Sentry dashboard > Settings
# > Projects > [project] > Client Keys). Leaving this blank disables Sentry
# entirely (see src/lib/sentry.ts) -- safe to leave unset until a project exists.
EXPO_PUBLIC_SENTRY_DSN=
# Only needed for EAS builds that upload source maps -- set as an EAS secret,
# not here. Local/dev builds work fine without them.
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
